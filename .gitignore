# Secrets — never commit
.env
.env.*
*.secret
secrets/
**/secrets.yaml
**/kubeconfig
**/talosconfig

# OpenTofu/Terraform state and secrets — never commit
*.tfstate
*.tfstate.*
.terraform/
# .terraform.lock.hcl is intentionally NOT ignored — commit it to pin provider versions
terraform.tfvars
tfplan

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Temp
*.tmp
*.bak
.worktrees/

# Ansible — ignore embedded .git if present
ansible/.git/
ansible/collections/
# Signed commits enabled
